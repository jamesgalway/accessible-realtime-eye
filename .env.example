# Copy this file to .env, then fill in your own keys.
# Do not commit .env if this project is made public.

PORT=8787
HOST=0.0.0.0

# Amap Web Service key. Keep it on the server side only.
AMAP_KEY=
AMAP_MIN_INTERVAL_MS=450

# Alibaba Cloud Model Studio / DashScope key.
# Either variable name works; BAILIAN_API_KEY has priority.
BAILIAN_API_KEY=
DASHSCOPE_API_KEY=
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_VISION_MODEL=qwen-vl-plus

# Realtime audio-video model.
# WebSocket mode works with the DashScope endpoint below.
# WebRTC mode also needs a whitelist Endpoint from Alibaba Cloud business support.
BAILIAN_REALTIME_MODEL=qwen3.5-omni-plus-realtime
BAILIAN_REALTIME_REGION=cn
BAILIAN_REALTIME_VOICE=Tina
BAILIAN_WEBRTC_ENDPOINT=
